name: Ενημέρωση πλειστηριασμών

on:
  schedule:
    - cron: "0 4 * * *"     # κάθε μέρα 04:00 UTC (07:00 Κύπρου)
  workflow_dispatch: {}      # και χειροκίνητα με ένα κουμπί

permissions:
  contents: write

jobs:
  scrape:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Εγκατάσταση βιβλιοθηκών
        run: pip install -r requirements.txt

      - name: Συλλογή δεδομένων
        run: python scraper.py
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}

      - name: Αποθήκευση στο repository
        run: |
          git config user.name "auction-bot"
          git config user.email "actions@users.noreply.github.com"
          git add data/ index.html report.html partners.html legal.html d/ p/ t/ og-image.png
          git add sitemap.xml robots.txt || true
          git diff --cached --quiet || git commit -m "Ενημέρωση δεδομένων $(date -u +%d/%m/%Y)"
          git push

